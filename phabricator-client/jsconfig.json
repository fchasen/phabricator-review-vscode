{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist-types",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "types": []
  },
  "include": ["index.js", "src/**/*.js"],
  "exclude": ["test", "dist-types", "**/node_modules"]
}
